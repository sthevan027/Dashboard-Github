# Token GitHub (Personal Access Token com escopo: repo, read:org)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx

# PIN para proteger o acesso ao dashboard (header x-app-pin)
APP_PIN=123456

# Opcional: URL pública do deploy (sem barra final).
# Na Vercel: deixe vazio — o frontend e /api ficam na mesma origem.
VITE_API_BASE=

# --- Deploy na Vercel (resumo) ---
# 1) Importe o repositório no painel da Vercel.
# 2) Em Settings > Environment Variables, crie GITHUB_TOKEN e APP_PIN (Production e Preview).
# 3) Deploy: o build usa pnpm run build; as funções em /api/* respondem junto ao site estático em /dist.
# 4) Local: copie este arquivo para .env, preencha os valores e rode: pnpm dev:full (Vite + Express na 3001).
