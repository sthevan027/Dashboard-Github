{
  "name": "github-dashboard-server",
  "version": "1.0.0",
  "description": "GitHub Dashboard API + frontend",
  "author": "Local",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "vite",
    "dev:full": "concurrently -k \"pnpm start\" \"pnpm dev\"",
    "electron:dev": "concurrently -k \"pnpm dev:full\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron:build": "cross-env NODE_ENV=production vite build && electron-builder"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "electron-winstaller"]
  },
  "build": {
    "appId": "com.githubdashboard.local",
    "productName": "GitHub Dashboard",
    "directories": {
      "output": "electron-release"
    },
    "files": ["dist/**/*", "electron/**/*.cjs"],
    "forceCodeSigning": false,
    "win": {
      "target": ["dir"],
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "lucide-react": "^0.468.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.5",
    "workbox-window": "^7.4.1"
  }
}
